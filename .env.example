# OpenAI — used for OCR on scanned PDFs (GPT-4o-mini Vision)
OPENAI_API_KEY=sk-...

# Stripe — payment processing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...    # One-time price at €2.99 per unit

# Auth — secret for HMAC-SHA256 free trial tokens
FREE_TRIAL_SECRET=change_me_to_a_random_64_char_string

# App URL — used for Stripe redirect URLs
APP_URL=https://your-app.vercel.app
